VITE_APP_URL=https://royshare.netlify.app
VITE_API_URL=https://<your-cloud-run-url>

# Admin Access Configuration (Required)
# Comma-separated list of fully approved admin gmail addresses.
VITE_ADMIN_EMAILS=roynoruless@gmail.com
